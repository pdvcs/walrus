{
  "name": "walrus",
  "version": "0.2.0",
  "description": "Smart package ingress system",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && npm run build:static",
    "build:static": "esbuild src/static/editor-bundle.ts --bundle --outfile=dist/public/editor-bundle.js --format=iife --platform=browser --minify",
    "typecheck": "tsc --noEmit",
    "dev": "npm run build:static && dotenv -e .env.local -- tsx watch src/main.ts",
    "test": "dotenv -e .env.local -e .env.secrets -- vitest run",
    "test:unit": "vitest run tests/common tests/discovery tests/services tests/scripts tests/vuln/normalize.test.ts tests/vuln/version-ranges.test.ts tests/vuln/cpe.test.ts tests/vuln/sync/nvd-client.test.ts",
    "test:integration": "dotenv -e .env.local -e .env.secrets -- vitest run tests/db",
    "migrate": "dotenv -e .env.local -e .env.secrets -- tsx src/db/client.ts migrate",
    "db:reset": "read -p 'Wipe walrus DB? [type \"yes\" to wipe] ' yn && [ \"$yn\" = yes ] && psql walrus -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public; GRANT ALL ON SCHEMA public TO walrus;' && npm run migrate || echo Aborted.",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "npm run lint:eslint && npm run lint:oxlint",
    "lint:eslint": "eslint src tests scripts",
    "lint:oxlint": "oxlint src tests scripts",
    "check-schemas": "tsx scripts/check-schemas.ts",
    "vuln:backfill": "dotenv -e .env.local -e .env.secrets -- tsx scripts/vuln-backfill.ts",
    "validate": "dotenv -e .env.local -- tsx scripts/validate-package.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@google-cloud/storage": "^7.16.0",
    "@iarna/toml": "^2.2.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "fast-xml-parser": "^5.5.5",
    "fuzzball": "^2.2.6",
    "jsonpath-plus": "^10.3.0",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "postgres-migrations": "^5.3.0",
    "semver": "^7.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/view": "^6.40.0",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.9",
    "@types/pg": "^8.11.11",
    "@types/semver": "^7.5.8",
    "@types/supertest": "^6.0.2",
    "codemirror": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.2",
    "fast-check": "^4.9.0",
    "msw": "^2.7.3",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">= 24.0.0"
  }
}
